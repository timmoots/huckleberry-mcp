# Huckleberry account (the same credentials the mobile app uses).
HUCKLEBERRY_EMAIL=your-email@example.com
HUCKLEBERRY_PASSWORD=your-password
HUCKLEBERRY_TIMEZONE=America/New_York

# Set this once you've picked a child to log against by default.
# Run list_children via MCP Inspector (stdio mode) to find the uid.
HUCKLEBERRY_DEFAULT_CHILD_UID=

# Transport. "stdio" for local dev / Claude Desktop; "streamable-http" for
# remote (Claude mobile / web via claude.ai Connectors).
MCP_TRANSPORT=stdio

# --- streamable-http only ---
# Public URL of this server (as seen by Claude). Used as the OAuth issuer.
OAUTH_ISSUER=https://huckleberry-mcp.fly.dev
# The password you type on the consent screen (once per refresh-token TTL — 30 days).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
OAUTH_ADMIN_PASSWORD=
PORT=8080
